<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="PLATEAU CityGML Importer for Revit"
           Version="1.0.0.0"
           Manufacturer="tutti-works"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Language="1033"
           Codepage="932">

    <SummaryInformation Keywords="Revit, PLATEAU, CityGML, Importer"
                       Description="PLATEAU CityGML data importer add-in for Autodesk Revit"
                       Manufacturer="tutti-works" />

    <!-- メジャーアップグレード設定 -->
    <MajorUpgrade DowngradeErrorMessage="新しいバージョンが既にインストールされています。" />

    <!-- メディア設定 -->
    <MediaTemplate EmbedCab="yes" />

    <!-- インストール先ディレクトリ構造 -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="PlateauRevitImporter">
        <Component Id="MainExecutable" Guid="B1C2D3E4-F5A6-7B8C-9D0E-F1A2B3C4D5E6">
          <File Id="PlateauRevitImporterDLL"
                Source="..\bin\Release\net8.0-windows\PlateauRevitImporter.dll"
                KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Revit 2025 Addins ディレクトリ -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="Autodesk" Name="Autodesk">
        <Directory Id="Revit" Name="Revit">
          <Directory Id="Addins2025" Name="Addins">
            <Directory Id="Addins2025Version" Name="2025">
              <Component Id="AddinFile2025" Guid="C2D3E4F5-A6B7-8C9D-0E1F-2A3B4C5D6E7F">
                <File Id="AddinFile2025"
                      Source="PlateauRevitImporter.addin"
                      KeyPath="yes" />
              </Component>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Revit 2026 Addins ディレクトリ -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="Autodesk2" Name="Autodesk">
        <Directory Id="Revit2" Name="Revit">
          <Directory Id="Addins2026" Name="Addins">
            <Directory Id="Addins2026Version" Name="2026">
              <Component Id="AddinFile2026" Guid="D3E4F5A6-B7C8-9D0E-1F2A-3B4C5D6E7F8A">
                <File Id="AddinFile2026"
                      Source="PlateauRevitImporter.addin"
                      KeyPath="yes" />
              </Component>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Revit 2027 Addins ディレクトリ -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="Autodesk3" Name="Autodesk">
        <Directory Id="Revit3" Name="Revit">
          <Directory Id="Addins2027" Name="Addins">
            <Directory Id="Addins2027Version" Name="2027">
              <Component Id="AddinFile2027" Guid="E4F5A6B7-C8D9-0E1F-2A3B-4C5D6E7F8A9B">
                <File Id="AddinFile2027"
                      Source="PlateauRevitImporter.addin"
                      KeyPath="yes" />
              </Component>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- インストールするコンポーネント -->
    <Feature Id="ProductFeature" Title="PLATEAU CityGML Importer" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="AddinFile2025" />
      <ComponentRef Id="AddinFile2026" />
      <ComponentRef Id="AddinFile2027" />
    </Feature>

  </Package>
</Wix>
